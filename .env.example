# Smart Itinerary 环境变量

# === 小米 MiMo API (必填，Anthropic 兼容协议) ===
MIMO_API_KEY=your-mimo-api-key-here
MIMO_BASE_URL=https://api.mimo.ai/v1
MIMO_MODEL=mimo-v2.5-pro

# === 小红书 MCP (Phase 1.4 启用) ===
# Python 小红书 MCP 项目路径
XHS_MCP_PATH=

